{
  "bats": {
    "source_extensions": [".sh", ".bats"],
    "lint_hook": "lint_format_sh.sh",
    "test_dirs": ["tests"],
    "test_patterns": ["{stem}.bats", "test_{stem}.bats"],
    "self_test_extensions": [".bats"],
    "fallback_on_unmatched_source": true
  },
  "python": {
    "source_extensions": [".py"],
    "lint_hook": "lint_format_py.sh",
    "test_dirs": ["."],
    "test_patterns": ["test_{stem}.py", "{stem}_test.py"],
    "self_test_globs": ["test_*.py", "*_test.py"],
    "exclude_dirs": [".venv", "node_modules"],
    "project_markers": ["pyproject.toml"],
    "fallback_on_unmatched_source": true
  },
  "javascript_typescript": {
    "source_extensions": [".js", ".jsx", ".ts", ".tsx"],
    "lint_hook": "lint_format_js.sh",
    "project_markers": ["package.json", "pnpm-lock.yaml", "tsconfig.json"],
    "test_dirs": ["."],
    "test_patterns": [
      "{stem}.test.js",
      "{stem}.spec.js",
      "{stem}.test.jsx",
      "{stem}.spec.jsx",
      "{stem}.test.ts",
      "{stem}.spec.ts",
      "{stem}.test.tsx",
      "{stem}.spec.tsx"
    ],
    "self_test_globs": [
      "*.test.js",
      "*.spec.js",
      "*.test.jsx",
      "*.spec.jsx",
      "*.test.ts",
      "*.spec.ts",
      "*.test.tsx",
      "*.spec.tsx"
    ],
    "strategy": "metadata_only"
  },
  "rust": {
    "source_extensions": [".rs"],
    "lint_hook": "lint_format_rs.sh",
    "project_markers": ["Cargo.toml"],
    "integration_test_dir": "tests",
    "source_dirs": ["src"],
    "skip_unit_filter_stems": ["lib", "main", "mod"],
    "strategy": "unit_filter_and_integration_targets"
  }
}
