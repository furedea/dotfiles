{
  "Anthropic API Key": {
    "pattern": "sk-ant-[0-9a-zA-Z\\-]{20,}",
    "message": "Anthropic API key detected"
  },
  "AWS Access Key": {
    "pattern": "AKIA[0-9A-Z]{16}",
    "message": "AWS Access Key ID detected"
  },
  "AWS Secret Key": {
    "pattern": "(?i)(aws_secret_access_key|aws_secret)\\s*[:=]\\s*[\"']?[0-9a-zA-Z/+=]{40}",
    "message": "AWS Secret Access Key detected"
  },
  "Bearer Token": {
    "pattern": "Bearer\\s+[a-zA-Z0-9_\\-/.+=]{20,}",
    "message": "Bearer token detected"
  },
  "Connection String": {
    "pattern": "(mysql|postgres|postgresql|mongodb|redis)://[^\\s\"']+",
    "message": "Database connection string detected"
  },
  "Generic Secret Assignment": {
    "pattern": "(?i)(api[_-]?key|api[_-]?secret|access[_-]?token|auth[_-]?token|secret[_-]?key|password)\\s*[:=]\\s*[\"']?[a-zA-Z0-9_\\-/.+=]{8,}",
    "message": "Generic secret assignment detected"
  },
  "GitHub Token": {
    "pattern": "gh[pousr]_[0-9a-zA-Z]{36,}",
    "message": "GitHub personal access token detected"
  },
  "OpenAI API Key": {
    "pattern": "sk-[0-9a-zA-Z]{20,}",
    "message": "OpenAI API key detected"
  },
  "Private Key": {
    "pattern": "-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY-----",
    "message": "Private key detected"
  }
}
