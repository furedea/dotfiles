{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 9999,
  "env": {
    "CLAUDE_CODE_NO_FLICKER": "1",
    "ENABLE_TOOL_SEARCH": "true",
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1"
  },
  "permissions": {
    "allow": [
      "Bash(afplay:*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm:*)",
      "Bash(rm -rf:*)",
      "Read(.env*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(**/*token*)",
      "Read(**/*key*)",
      "Write(.env*)",
      "Write(**/secrets/**)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(nc:*)",
      "Bash(pip:*)",
      "Bash(uv remove:*)",
      "Bash(uv uninstall:*)",
      "Bash(npm uninstall:*)",
      "Bash(npm remove:*)",
      "Bash(psql:*)",
      "Bash(mysql:*)",
      "Bash(mongod:*)"
    ],
    "defaultMode": "auto"
  },
  "model": "opus",
  "enableAllProjectMcpServers": false,
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/scan_sensitive_info.sh prompt"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/check_prohibited_commands.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/scan_sensitive_info.sh read"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/scan_sensitive_info.sh write"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/lint_format_py.sh",
            "if": "Write(*.py)|Edit(*.py)|MultiEdit(*.py)"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/lint_format_sh.sh",
            "if": "Write(*.sh)|Edit(*.sh)|MultiEdit(*.sh)"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/lint_format_js.sh",
            "if": "Write(*.js)|Edit(*.js)|MultiEdit(*.js)|Write(*.ts)|Edit(*.ts)|MultiEdit(*.ts)|Write(*.jsx)|Edit(*.jsx)|MultiEdit(*.jsx)|Write(*.tsx)|Edit(*.tsx)|MultiEdit(*.tsx)"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/lint_format_rs.sh",
            "if": "Write(*.rs)|Edit(*.rs)|MultiEdit(*.rs)"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/lint_format_nix.sh",
            "if": "Write(*.nix)|Edit(*.nix)|MultiEdit(*.nix)"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/lint_format_md.sh",
            "if": "Write(*.md)|Edit(*.md)|MultiEdit(*.md)|Write(*.markdown)|Edit(*.markdown)|MultiEdit(*.markdown)"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/lint_format_json_toml.sh",
            "if": "Write(*.json)|Edit(*.json)|MultiEdit(*.json)|Write(*.toml)|Edit(*.toml)|MultiEdit(*.toml)"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/lint_format_gha.sh",
            "if": "Write(*.yml)|Edit(*.yml)|MultiEdit(*.yml)|Write(*.yaml)|Edit(*.yaml)|MultiEdit(*.yaml)"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/lint_format_txt.sh",
            "if": "Write(*.txt)|Edit(*.txt)|MultiEdit(*.txt)"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/lint_format_lua.sh",
            "if": "Write(*.lua)|Edit(*.lua)|MultiEdit(*.lua)"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/lint_format_tex.sh",
            "if": "Write(*.tex)|Edit(*.tex)|MultiEdit(*.tex)|Write(*.bib)|Edit(*.bib)|MultiEdit(*.bib)|Write(*.cls)|Edit(*.cls)|MultiEdit(*.cls)|Write(*.sty)|Edit(*.sty)|MultiEdit(*.sty)"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/macos_notify_done.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/macos_notify_await.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/statuslines/statusline.sh"
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "playwright@claude-plugins-official": false,
    "chrome-devtools-mcp@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": false,
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "language": "Japanese",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": false,
    "allowUnsandboxedCommands": true,
    "network": {
      "allowedDomains": [
        "api.day.app"
      ]
    },
    "excludedCommands": [
      "docker",
      "watchman"
    ]
  },
  "effortLevel": "max",
  "autoMemoryEnabled": false,
  "feedbackSurveyState": {
    "lastShownTime": 1754030513973
  },
  "skipAutoPermissionPrompt": true
}
