{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 9999,
  "env": {
    "CLAUDE_CODE_NO_FLICKER": "1",
    "ENABLE_TOOL_SEARCH": "true",
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1"
  },
  "permissions": {
    "allow": [
      "Bash(actionlint:*)",
      "Bash(autocorrect:*)",
      "Bash(bats:*)",
      "Bash(cargo:*)",
      "Bash(commitlint:*)",
      "Bash(deadnix:*)",
      "Bash(dprint:*)",
      "Bash(gh api:*)",
      "Bash(gh issue:*)",
      "Bash(gh label:*)",
      "Bash(gh pr:*)",
      "Bash(gh run:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git commit:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(nixfmt:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(oxfmt:*)",
      "Bash(oxlint:*)",
      "Bash(pnpm:*)",
      "Bash(prettierd:*)",
      "Bash(selene:*)",
      "Bash(shellcheck:*)",
      "Bash(shfmt:*)",
      "Bash(statix:*)",
      "Bash(stylua:*)",
      "Bash(tex-fmt:*)",
      "Bash(tsgolint:*)",
      "Bash(uv run:*)",
      "Skill(lock-settings)",
      "Skill(report-hook-block)",
      "Skill(report-doc-conflict)"
    ],
    "deny": [
      "Bash(curl:*)",
      "Bash(defaults write:*)",
      "Bash(docker push:*)",
      "Bash(git branch -D:*)",
      "Bash(git clean:*)",
      "Bash(git filter-branch:*)",
      "Bash(git filter-repo:*)",
      "Bash(git gc --prune:*)",
      "Bash(git reflog delete:*)",
      "Bash(git reflog expire:*)",
      "Bash(git replace:*)",
      "Bash(git rm:*)",
      "Bash(git stash clear:*)",
      "Bash(git stash drop:*)",
      "Bash(git switch --discard-changes:*)",
      "Bash(git symbolic-ref --delete:*)",
      "Bash(git symbolic-ref -d:*)",
      "Bash(git update-ref -d:*)",
      "Bash(git worktree remove:*)",
      "Bash(kubectl apply:*)",
      "Bash(kubectl delete:*)",
      "Bash(mongod:*)",
      "Bash(mysql:*)",
      "Bash(nc:*)",
      "Bash(npm publish:*)",
      "Bash(npm remove:*)",
      "Bash(npm uninstall:*)",
      "Bash(open:*)",
      "Bash(osascript:*)",
      "Bash(pip:*)",
      "Bash(psql:*)",
      "Bash(rm:*)",
      "Bash(rm -rf:*)",
      "Bash(rsync:*)",
      "Bash(scp:*)",
      "Bash(ssh:*)",
      "Bash(sudo:*)",
      "Bash(terraform apply:*)",
      "Bash(terraform destroy:*)",
      "Bash(uv remove:*)",
      "Bash(uv uninstall:*)",
      "Bash(wget:*)",
      "Read(.env*)",
      "Read(**/*key*)",
      "Read(**/*token*)",
      "Read(~/.aws/**)",
      "Read(~/.bash_history)",
      "Read(~/.docker/config.json)",
      "Read(~/.kube/**)",
      "Read(~/.zsh_history)",
      "Read(credentials.json)",
      "Read(id_ed25519)",
      "Read(id_rsa)",
      "Read(service-account*.json)",
      "Write(.env*)",
      "Write(**/secrets/**)"
    ],
    "defaultMode": "auto"
  },
  "model": "opus",
  "enableAllProjectMcpServers": false,
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/block_secret_content.sh prompt"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/prevent_secret_commit.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/block_no_verify.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/block_add_all.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/block_dangerous_git.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/command_allowlist.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/block_secret_content.sh read"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/block_secret_content.sh write"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/lint_format_py.sh",
            "if": "Write(*.py)|Edit(*.py)|MultiEdit(*.py)"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/lint_format_sh.sh",
            "if": "Write(*.sh)|Edit(*.sh)|MultiEdit(*.sh)"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/lint_format_js.sh",
            "if": "Write(*.js)|Edit(*.js)|MultiEdit(*.js)|Write(*.ts)|Edit(*.ts)|MultiEdit(*.ts)|Write(*.jsx)|Edit(*.jsx)|MultiEdit(*.jsx)|Write(*.tsx)|Edit(*.tsx)|MultiEdit(*.tsx)"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/lint_format_rs.sh",
            "if": "Write(*.rs)|Edit(*.rs)|MultiEdit(*.rs)"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/lint_format_nix.sh",
            "if": "Write(*.nix)|Edit(*.nix)|MultiEdit(*.nix)"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/lint_format_md.sh",
            "if": "Write(*.md)|Edit(*.md)|MultiEdit(*.md)|Write(*.markdown)|Edit(*.markdown)|MultiEdit(*.markdown)"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/lint_format_json_toml.sh",
            "if": "Write(*.json)|Edit(*.json)|MultiEdit(*.json)|Write(*.toml)|Edit(*.toml)|MultiEdit(*.toml)"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/lint_format_gha.sh",
            "if": "Write(*.yml)|Edit(*.yml)|MultiEdit(*.yml)|Write(*.yaml)|Edit(*.yaml)|MultiEdit(*.yaml)"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/lint_format_txt.sh",
            "if": "Write(*.txt)|Edit(*.txt)|MultiEdit(*.txt)"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/lint_format_lua.sh",
            "if": "Write(*.lua)|Edit(*.lua)|MultiEdit(*.lua)"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/lint_format_tex.sh",
            "if": "Write(*.tex)|Edit(*.tex)|MultiEdit(*.tex)|Write(*.bib)|Edit(*.bib)|MultiEdit(*.bib)|Write(*.cls)|Edit(*.cls)|MultiEdit(*.cls)|Write(*.sty)|Edit(*.sty)|MultiEdit(*.sty)"
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|WebFetch|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/log_tool_call.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/macos_notify_done.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/macos_notify_await.sh"
          }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/log_permission_denied.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/statusline/statusline.sh"
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "playwright@claude-plugins-official": false,
    "chrome-devtools-mcp@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": false,
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "language": "Japanese",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": false,
    "allowUnsandboxedCommands": true,
    "network": {
      "allowedDomains": [
        "api.day.app"
      ]
    },
    "excludedCommands": [
      "docker",
      "watchman"
    ]
  },
  "effortLevel": "xhigh",
  "autoMemoryEnabled": false,
  "skipAutoPermissionPrompt": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754030513973
  }
}
