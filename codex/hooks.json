{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.codex/hooks/scan_sensitive_info.sh prompt",
            "statusMessage": "Scanning prompt for sensitive information",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/check_prohibited_commands.sh",
            "statusMessage": "Checking command policy",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "^apply_patch$|^Edit$|^Write$",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.codex/hooks/scan_sensitive_info.sh apply-patch",
            "statusMessage": "Scanning patch for sensitive information",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^apply_patch$|^Edit$|^Write$",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.codex/hooks/post_apply_patch_lint_format.sh",
            "statusMessage": "Running lint/format hooks",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
