{
  "name": "typescript-project",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "typecheck": "oxlint --type-aware --type-check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "knip": "knip",
    "check": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run knip"
  },
  "devDependencies": {
    "@types/node": "latest",
    "typescript": "latest",
    "oxfmt": "latest",
    "oxlint": "latest",
    "oxlint-tsgolint": "latest",
    "vitest": "latest",
    "knip": "latest"
  }
}
